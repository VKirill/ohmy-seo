# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_YANDEX_SEO_MASTER_KEY=

# optional, default ./data/state.db
MCP_YANDEX_SEO_DB_PATH=

# optional, only for mutagen_competition tool
MUTAGEN_API_KEY=

# optional, set to true to hit Direct sandbox
DIRECT_USE_SANDBOX=false

# optional
HTTP_TIMEOUT_MS=30000

# Inventory cache TTL in hours; falls back to 24 if invalid/empty
MCP_YANDEX_SEO_CACHE_TTL_HOURS=24

# Query cache TTL overrides (seconds); each optional, defaults shown in comments
MCP_YANDEX_SEO_CACHE_TTL_WORDSTAT_KEYWORDS=604800       # 7 days
MCP_YANDEX_SEO_CACHE_TTL_MUTAGEN_COMPETITION=2592000    # 30 days
MCP_YANDEX_SEO_CACHE_TTL_WEBMASTER_TOP_QUERIES=3600     # 1 hour
MCP_YANDEX_SEO_CACHE_TTL_METRIKA_SEARCH_PHRASES=3600    # 1 hour
MCP_YANDEX_SEO_CACHE_TTL_WEBMASTER_INDEXING_ISSUES=3600 # 1 hour
MCP_YANDEX_SEO_CACHE_TTL_WEBMASTER_SITE_SUMMARY=21600   # 6 hours
MCP_YANDEX_SEO_CACHE_TTL_METRIKA_TRAFFIC_SUMMARY=21600  # 6 hours
