# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_XMLSTOCK_MASTER_KEY=<placeholder>

# optional, default ./data/state.db
MCP_XMLSTOCK_DB_PATH=./data/state.db

# XMLStock API credentials (required for live calls)
XMLSTOCK_USER=
XMLSTOCK_KEY=

# Cache TTL for SERP results (seconds); default 86400 (24 hours)
MCP_XMLSTOCK_CACHE_TTL_SERP=86400

# Cache TTL for usage/stats results (seconds); default 300 (5 minutes)
MCP_XMLSTOCK_CACHE_TTL_STATS=300
