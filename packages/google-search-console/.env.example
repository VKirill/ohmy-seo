# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_GSC_MASTER_KEY=<placeholder>

# optional, default ./data/state.db
MCP_GSC_DB_PATH=./data/state.db

# Cache TTL for search analytics results (seconds); default 1 hour
MCP_GSC_CACHE_TTL_SEARCH=3600

# Cache TTL for site/sitemap listings (seconds); default 24 hours
MCP_GSC_CACHE_TTL_META=86400

# Cache TTL for URL inspection results (seconds); default 1 hour
MCP_GSC_CACHE_TTL_INSPECT=3600

# Loopback port for OAuth redirect (default 8765)
MCP_GSC_OAUTH_LOOPBACK_PORT=8765
