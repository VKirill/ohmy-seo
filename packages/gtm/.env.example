# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_GTM_MASTER_KEY=<placeholder>

# optional, default ./data/state.db
MCP_GTM_DB_PATH=./data/state.db

# Cache TTL for read operations (seconds); default 1 hour
MCP_GTM_CACHE_TTL_READ=3600

# Cache TTL for version listings (seconds); default 5 minutes (active edit cycle)
MCP_GTM_CACHE_TTL_VERSIONS=300

# Loopback port for OAuth redirect (default 8767)
MCP_GTM_OAUTH_LOOPBACK_PORT=8767
