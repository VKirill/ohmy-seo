# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_MUTAGEN_MASTER_KEY=<placeholder>

# optional, default ./data/state.db
MCP_MUTAGEN_DB_PATH=./data/state.db

# Mutagen.ru API key. Required for mutagen_competition and mutagen_api tools.
# Get a key: https://mutagen.ru/?r=69383
MUTAGEN_API_KEY=

# Query cache TTL for Mutagen results (seconds); default 30 days
MCP_MUTAGEN_CACHE_TTL=2592000
