# 32 hex bytes, generate via `openssl rand -hex 32`. Required.
MCP_GA4_MASTER_KEY=<placeholder>

# optional, default ./data/state.db
MCP_GA4_DB_PATH=./data/state.db

# Cache TTL for report results (seconds); default 1 hour
MCP_GA4_CACHE_TTL_REPORT=3600

# Cache TTL for property/dimension/metric listings (seconds); default 24 hours
MCP_GA4_CACHE_TTL_META=86400

# Loopback port for OAuth redirect (default 8766)
MCP_GA4_OAUTH_LOOPBACK_PORT=8766
